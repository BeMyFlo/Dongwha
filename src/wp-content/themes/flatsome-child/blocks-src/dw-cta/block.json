{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "dw/cta",
  "version": "0.1.0",
  "title": "Dongwha CTA",
  "category": "text",
  "description": "Call to action section with glassmorphism for Dongwha homepage",
  "attributes": {
    "title": {
      "type": "string",
      "default": "Bạn đã sẵn sàng nâng tầm không gian sống?"
    },
    "subtitle": {
      "type": "string",
      "default": "Liên hệ ngay với chúng tôi để được tư vấn giải pháp nội thất gỗ công nghiệp tối ưu nhất."
    },
    "btnText": {
      "type": "string",
      "default": "NHẬN BÁO GIÁ NGAY"
    },
    "btnLink": {
      "type": "string",
      "default": "#"
    },
    "backgroundImage": {
      "type": "string",
      "default": "https://images.unsplash.com/photo-1618221195710-dd6b41faaea6?q=80&w=1800&auto=format&fit=crop"
    },
    "paddingTop": {
      "type": "number",
      "default": 140
    },
    "paddingBottom": {
      "type": "number",
      "default": 140
    }
  },
  "supports": {
    "html": false,
    "align": ["wide", "full"]
  },
  "textdomain": "dw-blocks",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./style-index.css",
  "style": "file:./style-index.css",
  "render": "file:./render.php"
}
